
env_names=(texlive homebrew darwin rust kitty custom proxychains nix proxyswitch)

for fn in "${env_names[@]}";
do
    fn=~/.profile.d/${fn}
    if [ -f "${fn}" ]; then
        . "${fn}"
    fi
done

if [ -x "$(command -v pyenv)" ]; then
    [ -f ~/.profile.d/pyenv ] && . ~/.profile.d/pyenv
fi

if [ -n "${XDG_CURRENT_DESKTOP}" ]; then
    source ~/.profile.d/desktop/im
fi

if [ "$XDG_SESSION_TYPE" = wayland ]; then
    source ~/.profile.d/desktop/xresources
fi
